{
  "name": "invoice-tokenization",
  "version": "1.0.0",
  "description": "Monorepo for invoice tokenization on Stellar",
  "private": true,
  "workspaces": [
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev --workspace=frontend",
    "test": "npm run test --workspaces",
    "clean": "npm run clean --workspaces && make clean"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
